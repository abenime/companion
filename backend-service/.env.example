# Express API Server Port Configuration
PORT=3000

# PostgreSQL Relational Timeseries Database Connection URL
# Example: postgresql://<user>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wellness_companion

# Secret key used for signing JWT Authentication tokens
JWT_SECRET=wellness_companion_secret_key_change_me_in_production

# Google Gemini Pro Generative AI Developer API Key
# Obtain one for free at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_goes_here

# Chapa Payment Gateway API Keys
# Get your keys at: https://dashboard.chapa.co/
CHAPA_SECRET_KEY=CHASECK_TEST-your_chapa_secret_key_goes_here
