# =================================================================
#  PASSIVE AI WELLNESS COMPANION - SHARED ENV CONFIGURATIONS
# =================================================================

# 1. BACKEND SERVICE ENVIRONMENT VARIABLES (backend-service/)
# Place a copy of this in backend-service/.env
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wellness_companion
JWT_SECRET=wellness_companion_secret_key_change_me_in_production
GEMINI_API_KEY=your_gemini_api_key_goes_here


# 2. DESKTOP TELEMETRY AGENT CONFIGURATIONS (desktop-agent/)
# Place a copy of this in desktop-agent/.env
WELLNESS_SERVER_URL=http://localhost:3000
WELLNESS_AUTH_TOKEN=your_jwt_auth_token_received_at_signup_or_login
